@model Azimzadeh_MVC_project.Models.Order
@{
    ViewBag.Title = "جزئیات سفارش " + Model.OrderNumber;
    
    var items = new List<Azimzadeh_MVC_project.Models.OrderItemViewModel>();
    if (!string.IsNullOrEmpty(Model.ItemsJson))
    {
        var serializer = new System.Web.Script.Serialization.JavaScriptSerializer();
        items = serializer.Deserialize<List<Azimzadeh_MVC_project.Models.OrderItemViewModel>>(Model.ItemsJson) ?? new List<Azimzadeh_MVC_project.Models.OrderItemViewModel>();
    }
}

<div class="row">
    <div class="col-lg-6">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-info-sign"></i> اطلاعات کلی سفارش
            </header>
            <div class="panel-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <td style="width: 30%;"><strong>شماره سفارش:</strong></td>
                            <td><span dir="ltr">@Model.OrderNumber</span></td>
                        </tr>
                        <tr>
                            <td><strong>تاریخ ثبت سفارش:</strong></td>
                            <td>@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <td><strong>آخرین بروزرسانی:</strong></td>
                            <td>@(Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm:ss") : "-")</td>
                        </tr>
                        <tr>
                            <td><strong>روش پرداخت:</strong></td>
                            <td>@Model.PaymentStatus</td>
                        </tr>
                        <tr>
                            <td><strong>جمع کل سفارش:</strong></td>
                            <td><strong style="color: #e53e3e;">@Model.TotalAmount.ToString("N0") ریال</strong></td>
                        </tr>
                        <tr>
                            <td><strong>وضعیت فعلی:</strong></td>
                            <td>
                                @{
                                    string badgeClass = "label label-warning";
                                    string badgeStyle = "";
                                    if (Model.OrderStatus == "تحویل شده" || Model.OrderStatus == "تکمیل شده") { badgeClass = "label label-success"; }
                                    else if (Model.OrderStatus == "لغو شده") { badgeClass = "label label-danger"; }
                                    else if (Model.OrderStatus == "ارسال شده") { badgeClass = "label label-info"; }
                                    else { badgeStyle = "color: #000;"; }
                                }
                                <span class="@badgeClass" style="@badgeStyle">@Model.OrderStatus</span>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="well" style="margin-top: 20px;">
                    <h4>تغییر وضعیت سفارش</h4>
                    @using (Html.BeginForm("UpdateStatus", "Orders", new { area = "Admin", id = Model.OrderId }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="form-group" style="display: flex; gap: 10px; align-items: center; margin-bottom: 0;">
                            <select name="status" class="form-control" style="max-width: 200px; display: inline-block;">
                                <option value="در حال پردازش" @(Model.OrderStatus == "در حال پردازش" ? "selected" : "")>در حال پردازش</option>
                                <option value="تایید شده" @(Model.OrderStatus == "تایید شده" ? "selected" : "")>تایید شده</option>
                                <option value="ارسال شده" @(Model.OrderStatus == "ارسال شده" ? "selected" : "")>ارسال شده</option>
                                <option value="تحویل شده" @(Model.OrderStatus == "تحویل شده" ? "selected" : "")>تحویل شده</option>
                                <option value="لغو شده" @(Model.OrderStatus == "لغو شده" ? "selected" : "")>لغو شده</option>
                            </select>
                            <button type="submit" class="btn btn-success">ثبت تغییر وضعیت</button>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>

    <div class="col-lg-6">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-user"></i> اطلاعات مشتری و ارسال
            </header>
            <div class="panel-body">
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <td style="width: 30%;"><strong>نام مشتری:</strong></td>
                            <td>@(Model.User != null ? Model.User.FullName : "کاربر ناشناس")</td>
                        </tr>
                        <tr>
                            <td><strong>ایمیل:</strong></td>
                            <td>@(Model.User != null ? Model.User.Email : "-")</td>
                        </tr>
                        <tr>
                            <td><strong>شماره تماس:</strong></td>
                            <td>@(Model.User != null ? Model.User.PhoneNumber : "-")</td>
                        </tr>
                        <tr>
                            <td><strong>استان / شهر:</strong></td>
                            <td>@(Model.UserAddress != null ? $"{Model.UserAddress.Province} / {Model.UserAddress.City}" : "-")</td>
                        </tr>
                        <tr>
                            <td><strong>آدرس پستی:</strong></td>
                            <td>@(Model.UserAddress != null ? Model.UserAddress.FullAddress : "-")</td>
                        </tr>
                        <tr>
                            <td><strong>کد پستی:</strong></td>
                            <td>@(Model.UserAddress != null ? Model.UserAddress.PostalCode : "-")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-list"></i> اقلام سفارش داده شده
            </header>
            <div class="panel-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>نام محصول</th>
                            <th class="text-center">تعداد</th>
                            <th style="text-align: left;">قیمت واحد</th>
                            <th style="text-align: left;">جمع جزء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in items)
                        {
                            <tr>
                                <td>@i</td>
                                <td><strong>@item.Title</strong></td>
                                <td class="text-center">@item.Quantity</td>
                                <td style="text-align: left;">@(((decimal)item.UnitPrice).ToString("N0")) ریال</td>
                                <td style="text-align: left;">@(((decimal)item.Total).ToString("N0")) ریال</td>
                            </tr>
                            i++;
                        }
                        <tr style="font-weight: bold; background: #f9f9f9;">
                            <td colspan="4" style="text-align: right;">جمع کل اقلام:</td>
                            <td style="text-align: left; color: #e53e3e; font-size: 16px;">@Model.TotalAmount.ToString("N0") ریال</td>
                        </tr>
                    </tbody>
                </table>

                <div style="margin-top: 20px;">
                    <a href="@Url.Action("Invoice", new { id = Model.OrderId })" class="btn btn-primary" style="margin-left: 10px;"><i class="icon-print"></i> مشاهده و چاپ فاکتور رسمی</a>
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="icon-arrow-left"></i> بازگشت به لیست سفارشات</a>
                </div>
            </div>
        </section>
    </div>
</div>
