@model IEnumerable<Azimzadeh_MVC_project.Models.SiteSetting>

@{
    ViewBag.Title = "تنظیمات سایت";
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                مدیریت تنظیمات عمومی وب‌سایت
            </header>
            
            <div class="panel-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>کلید تنظیم</th>
                                <th>توضیحات</th>
                                <th>مقدار فعلی</th>
                                <th>نوع مقدار</th>
                                <th>تاریخ بروزرسانی</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td><strong>@item.SettingKey</strong></td>
                                        <td>@item.Description</td>
                                        <td>
                                            @if (string.IsNullOrEmpty(item.SettingValue))
                                            {
                                                <span class="text-muted">(خالی)</span>
                                            }
                                            else
                                            {
                                                <div style="max-width: 300px; word-wrap: break-word;">@item.SettingValue</div>
                                            }
                                        </td>
                                        <td>
                                            <span class="label label-info">@item.ValueType</span>
                                        </td>
                                        <td>@item.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                        <td>
                                            @Html.ActionLink("ویرایش", "Edit", new { id = item.SettingId }, new { @class = "btn btn-primary btn-xs" })
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>
</div>
