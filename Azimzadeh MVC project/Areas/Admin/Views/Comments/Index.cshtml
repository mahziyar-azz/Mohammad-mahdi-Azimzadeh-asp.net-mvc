@model List<Azimzadeh_MVC_project.Models.Comment>
@{
    ViewBag.Title = "مدیریت دیدگاه‌ها";
    string returnUrl = Request.Url.PathAndQuery;
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
                    <span><i class="icon-comments"></i> مدیریت دیدگاه‌ها &nbsp;<span class="badge bg-primary">@ViewBag.Total</span></span>
                    <div>
                        <a href="@Url.Action("Index", new { filter = "all" })" class="btn btn-xs @(ViewBag.Filter == "all" ? "btn-primary" : "btn-default")">همه</a>
                        <a href="@Url.Action("Index", new { filter = "product" })" class="btn btn-xs @(ViewBag.Filter == "product" ? "btn-primary" : "btn-default")">محصول</a>
                        <a href="@Url.Action("Index", new { filter = "blog" })" class="btn btn-xs @(ViewBag.Filter == "blog" ? "btn-primary" : "btn-default")">وبلاگ</a>
                        <a href="@Url.Action("Index", new { filter = "pending" })" class="btn btn-xs @(ViewBag.Filter == "pending" ? "btn-warning" : "btn-default")">در انتظار تأیید</a>
                    </div>
                </div>
            </header>
            <div class="panel-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">هیچ دیدگاهی یافت نشد.</div>
                }
                else
                {
                    <table class="table table-striped table-hover table-advance">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>فرستنده</th>
                                <th>نوع</th>
                                <th>متن دیدگاه</th>
                                <th>وضعیت</th>
                                <th>تاریخ</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var comm in Model)
                            {
                                string userName = "مهمان";
                                if (comm.User != null) { userName = comm.User.FullName; }
                                <tr>
                                    <td>@rowNum</td>
                                    <td><strong>@userName</strong></td>
                                    <td>
                                        @if (comm.TargetType == "Product")
                                        {
                                            <span class="label label-info label-mini">محصول</span>
                                        }
                                        else
                                        {
                                            <span class="label label-primary label-mini">وبلاگ</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="max-width:320px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@comm.Content">
                                            @comm.Content
                                        </div>
                                    </td>
                                    <td>
                                        @if (comm.IsApproved)
                                        {
                                            <span class="label label-success label-mini">تأیید شده</span>
                                        }
                                        else
                                        {
                                            <span class="label label-warning label-mini">در انتظار</span>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">@comm.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td style="white-space:nowrap;">
                                        @* Approve/Reject Toggle *@
                                        @using (Html.BeginForm("Approve", "Comments", new { area = "Admin", id = comm.CommentId }, FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            if (comm.IsApproved)
                                            {
                                                <button type="submit" class="btn btn-warning btn-xs" title="رد کردن">
                                                    <i class="icon-remove"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-success btn-xs" title="تأیید">
                                                    <i class="icon-ok"></i>
                                                </button>
                                            }
                                        }
                                        @* Edit *@
                                        <a href="@Url.Action("Edit", "Comments", new { area = "Admin", id = comm.CommentId })" class="btn btn-primary btn-xs" title="ویرایش">
                                            <i class="icon-pencil"></i>
                                        </a>
                                        @* Delete *@
                                        @using (Html.BeginForm("Delete", "Comments", new { area = "Admin", id = comm.CommentId }, FormMethod.Post, new { style = "display:inline;", onsubmit = "return confirm('آیا از حذف این دیدگاه مطمئن هستید؟');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                            <button type="submit" class="btn btn-danger btn-xs" title="حذف">
                                                <i class="icon-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }

                @* Pagination *@
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <div class="text-center">
                        <ul class="pagination pagination-sm">
                            @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                            {
                                <li class="@(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { filter = ViewBag.Filter, page = p })">@p</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
