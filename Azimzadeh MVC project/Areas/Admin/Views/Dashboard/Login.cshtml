@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="پنل مدیریت فلت لب">
    <meta name="author" content="Mosaddek">
    <meta name="keyword" content="FlatLab, Dashboard, Bootstrap, Admin, Template, Theme, Responsive, Fluid, Retina">
    <link rel="shortcut icon" href="/assets/admin/img/favicon.ico">

    <title>ورود به پنل مدیریت - فلت لب</title>

    <!-- Bootstrap core CSS -->
    <link href="/assets/admin/css/bootstrap.min.css" rel="stylesheet">
    <link href="/assets/admin/css/bootstrap-reset.css" rel="stylesheet">
    <!--external css-->
    <link href="/assets/admin/assets/font-awesome/css/font-awesome.css" rel="stylesheet" />
    <!-- Custom styles for this template -->
    <link href="/assets/admin/css/style.css" rel="stylesheet">
    <link href="/assets/admin/css/style-responsive.css" rel="stylesheet" />

    <!-- HTML5 shim and Respond.js IE8 support of HTML5 tooltipss and media queries -->
    <!--[if lt IE 9]>
    <script src="/assets/admin/js/html5shiv.js"></script>
    <script src="/assets/admin/js/respond.min.js"></script>
    <![endif]-->
</head>

<body class="login-body">
    <div class="container">
        <form class="form-signin" action="/Admin/Login" method="post" style="margin-top: 120px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            
            <h2 class="form-signin-heading" style="background-color: #ff6c60;">ورود به پنل مدیریت</h2>
            
            <div class="login-wrap">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger" style="margin-bottom: 15px; font-size: 12px; padding: 10px;">
                        @TempData["ErrorMessage"]
                    </div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success" style="margin-bottom: 15px; font-size: 12px; padding: 10px;">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <input type="email" name="email" class="form-control" placeholder="آدرس ایمیل مدیر" required autofocus style="margin-bottom: 15px;">
                <input type="password" name="password" class="form-control" placeholder="کلمه عبور" required style="margin-bottom: 15px;">
                
                <label class="checkbox" style="padding-right: 20px; margin-bottom: 15px; font-size: 12px; font-weight: normal; color: #797979;">
                    <input type="checkbox" name="rememberMe" value="true"> مرا به خاطر بسپار
                </label>
                
                <button class="btn btn-lg btn-login btn-block" type="submit" style="background-color: #ff6c60; color: #fff; border: none; font-size: 14px; padding: 10px;">
                    ورود به پنل
                </button>
                
                <div style="text-align: center; margin-top: 15px;">
                    <a href="/" style="font-size: 12px; color: #41cac0; text-decoration: underline;">بازگشت به فروشگاه</a>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
