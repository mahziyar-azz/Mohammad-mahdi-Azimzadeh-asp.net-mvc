@model Azimzadeh_MVC_project.Models.Gallery
@{
    ViewBag.Title = "افزودن تصویر جدید به گالری";
}

<div class="row">
    <div class="col-lg-8 col-lg-offset-2">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-plus"></i> افزودن تصویر جدید به گالری
            </header>
            
            <div class="panel-body">
                @using (Html.BeginForm("Create", "Gallery", FormMethod.Post, new { @class = "form-horizontal tasi-form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger" })

                    <div class="form-group">
                        @Html.LabelFor(model => model.Title, "عنوان تصویر", new { @class = "col-lg-3 control-label" })
                        <div class="col-lg-9">
                            @Html.TextBoxFor(model => model.Title, new { @class = "form-control", placeholder = "مثال: مته گیر برقی رونیکس", required = "required" })
                            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Description, "توضیحات کوتاه", new { @class = "col-lg-3 control-label" })
                        <div class="col-lg-9">
                            @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "3", placeholder = "مثال: مشخصات فنی یا تصویر با کیفیت از محصول" })
                            @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-lg-3 control-label">انتخاب فایل تصویر*</label>
                        <div class="col-lg-9">
                            <input type="file" name="imageFile" class="form-control" required="required" accept="image/*" />
                            @Html.ValidationMessage("ImagePath", "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.DisplayOrder, "ترتیب نمایش", new { @class = "col-lg-3 control-label" })
                        <div class="col-lg-9">
                            @Html.TextBoxFor(model => model.DisplayOrder, new { @class = "form-control", type = "number" })
                            @Html.ValidationMessageFor(model => model.DisplayOrder, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.IsActive, "وضعیت فعال بودن", new { @class = "col-lg-3 control-label" })
                        <div class="col-lg-9">
                            <div class="checkbox">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsActive) فعال باشد
                                </label>
                            </div>
                            @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-lg-offset-3 col-lg-9">
                            <button type="submit" class="btn btn-success">ثبت تصویر</button>
                            <a href="@Url.Action("Index", "Gallery", new { area = "Admin" })" class="btn btn-default">انصراف</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
