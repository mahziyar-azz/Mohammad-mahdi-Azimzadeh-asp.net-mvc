@model List<Azimzadeh_MVC_project.Models.Slider>
@{
    ViewBag.Title = "مدیریت اسلایدرها";
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-picture"></i> مدیریت اسلایدرهای صفحه اصلی
                <a href="@Url.Action("Create", "Sliders", new { area = "Admin" })" class="btn btn-success btn-sm pull-left" style="margin-top: -4px;">
                    <i class="icon-plus"></i> افزودن اسلایدر جدید
                </a>
            </header>
            <div class="panel-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">هیچ اسلایدری یافت نشد. برای شروع دکمه «افزودن اسلایدر جدید» را کلیک کنید.</div>
                }
                else
                {
                    <table class="table table-striped table-hover table-advance">
                        <thead>
                            <tr>
                                <th style="width: 8%;">#</th>
                                <th style="width: 15%;">تصویر</th>
                                <th>عنوان اصلی</th>
                                <th>عنوان فرعی</th>
                                <th style="width: 12%; text-align: center;">ترتیب نمایش</th>
                                <th style="width: 10%;">وضعیت</th>
                                <th style="width: 15%;">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var slider in Model)
                            {
                                <tr>
                                    <td>@rowNum</td>
                                    <td>
                                        <img src="@slider.ImagePath" alt="@slider.Title" style="max-height: 50px; max-width: 120px; border-radius: 4px; border: 1px solid #ddd;" />
                                    </td>
                                    <td><strong>@slider.Title</strong></td>
                                    <td>@slider.Subtitle</td>
                                    <td style="text-align: center;">@slider.DisplayOrder</td>
                                    <td>
                                        @if (slider.IsActive)
                                        {
                                            <span class="label label-success label-mini">فعال</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger label-mini">غیرفعال</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Edit", "Sliders", new { area = "Admin", id = slider.SliderId })" class="btn btn-primary btn-xs" title="ویرایش">
                                            <i class="icon-pencil"></i>
                                        </a>

                                        @using (Html.BeginForm("ToggleActive", "Sliders", new { area = "Admin", id = slider.SliderId }, FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            if (slider.IsActive)
                                            {
                                                <button type="submit" class="btn btn-warning btn-xs" title="غیرفعال کردن">
                                                    <i class="icon-eye-close"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-success btn-xs" title="فعال کردن">
                                                    <i class="icon-eye-open"></i>
                                                </button>
                                            }
                                        }

                                        @using (Html.BeginForm("Delete", "Sliders", new { area = "Admin", id = slider.SliderId }, FormMethod.Post, new { style = "display:inline;", onsubmit = "return confirm('آیا از حذف این اسلایدر مطمئن هستید؟');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-xs" title="حذف">
                                                <i class="icon-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>
    </div>
</div>
