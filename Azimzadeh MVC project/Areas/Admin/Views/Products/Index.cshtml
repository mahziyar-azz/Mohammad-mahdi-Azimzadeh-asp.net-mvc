@model List<Azimzadeh_MVC_project.Models.Product>
@{
    ViewBag.Title = "مدیریت محصولات";
    var categories = ViewBag.Categories as List<Azimzadeh_MVC_project.Models.Category>;
    int? selectedCatId = ViewBag.SelectedCategoryId as int?;
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-tags"></i> مدیریت محصولات &nbsp;<span class="badge bg-primary">@ViewBag.Total</span>
                <a href="@Url.Action("Create", "Products", new { area = "Admin" })" class="btn btn-success btn-sm pull-left" style="margin-top: -4px;">
                    <i class="icon-plus"></i> افزودن محصول جدید
                </a>
            </header>
            
            <div class="panel-body">
                @* Category Filtering Toolbar *@
                <div class="well well-sm" style="margin-bottom: 20px;">
                    @using (Html.BeginForm("Index", "Products", FormMethod.Get, new { @class = "form-inline", style = "margin: 0;" }))
                    {
                        <div class="form-group" style="margin-left: 10px;">
                            <label for="categoryId" style="margin-left: 5px; font-weight: bold;">فیلتر بر اساس دسته‌بندی:</label>
                            <select name="categoryId" id="categoryId" class="form-control input-sm">
                                <option value="">همه دسته‌بندی‌ها</option>
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat.CategoryId" @(cat.CategoryId == selectedCatId ? "selected" : "")>@cat.Title</option>
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="icon-filter"></i> اعمال فیلتر</button>
                        if (selectedCatId.HasValue)
                        {
                            <a href="@Url.Action("Index", "Products", new { area = "Admin" })" class="btn btn-default btn-sm" style="margin-right: 5px;"><i class="icon-refresh"></i> پاک کردن فیلتر</a>
                        }
                    }
                </div>

                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">هیچ محصولی با شرایط انتخاب‌شده یافت نشد.</div>
                }
                else
                {
                    <table class="table table-striped table-hover table-advance">
                        <thead>
                            <tr>
                                <th style="width: 5%;">#</th>
                                <th style="width: 10%;">تصویر</th>
                                <th>عنوان</th>
                                <th style="width: 15%;">دسته‌بندی</th>
                                <th style="width: 12%;">قیمت (ریال)</th>
                                <th style="width: 10%;">موجودی</th>
                                <th style="width: 12%;">SKU</th>
                                <th style="width: 8%;">وضعیت</th>
                                <th style="width: 18%;">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var prod in Model)
                            {
                                string catName = "-";
                                if (prod.Category != null) { catName = prod.Category.Title; }
                                
                                string mainImg = "/assets/img/products/default.jpg";
                                var mainProductImg = prod.ProductImages.FirstOrDefault(pi => pi.IsMain);
                                if (mainProductImg != null)
                                {
                                    mainImg = mainProductImg.ImagePath;
                                }
                                
                                <tr>
                                    <td>@rowNum</td>
                                    <td>
                                        <img src="@mainImg" alt="@prod.Title" style="max-height: 40px; max-width: 60px; border-radius: 4px; border: 1px solid #ddd;" />
                                    </td>
                                    <td>
                                        <div style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@prod.Title">
                                            <a href="/Home/Product?id=@prod.ProductId" target="_blank">@prod.Title</a>
                                        </div>
                                    </td>
                                    <td>@catName</td>
                                    <td>@prod.Price.ToString("N0")</td>
                                    <td>
                                        @if (prod.StockQuantity <= 5)
                                        {
                                            <span class="label label-danger label-mini">@prod.StockQuantity</span>
                                        }
                                        else
                                        {
                                            <span class="label label-success label-mini">@prod.StockQuantity</span>
                                        }
                                    </td>
                                    <td><code>@prod.SKU</code></td>
                                    <td>
                                        @if (prod.IsActive)
                                        {
                                            <span class="label label-success label-mini">فعال</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger label-mini">غیرفعال</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Edit", "Products", new { area = "Admin", id = prod.ProductId })" class="btn btn-primary btn-xs" title="ویرایش">
                                            <i class="icon-pencil"></i> ویرایش
                                        </a>

                                        @using (Html.BeginForm("ToggleActive", "Products", new { area = "Admin", id = prod.ProductId }, FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            if (prod.IsActive)
                                            {
                                                <button type="submit" class="btn btn-warning btn-xs" title="غیرفعال کردن">
                                                    <i class="icon-ban-circle"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-success btn-xs" title="فعال کردن">
                                                    <i class="icon-ok"></i>
                                                </button>
                                            }
                                        }

                                        @using (Html.BeginForm("Delete", "Products", new { area = "Admin", id = prod.ProductId }, FormMethod.Post, new { style = "display:inline;", onsubmit = "return confirm('آیا از حذف این محصول و تمامی اطلاعات وابسته به آن مطمئن هستید؟');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-xs" title="حذف کامل">
                                                <i class="icon-trash"></i> حذف
                                            </button>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }

                @* Pagination *@
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <div class="text-center">
                        <ul class="pagination pagination-sm">
                            @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                            {
                                <li class="@(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { page = p, categoryId = selectedCatId })">@p</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
