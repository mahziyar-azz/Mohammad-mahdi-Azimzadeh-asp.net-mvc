@model List<Azimzadeh_MVC_project.Models.User>
@{
    ViewBag.Title = "مدیریت کاربران";
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-user"></i> مدیریت کاربران &nbsp;<span class="badge bg-primary">@ViewBag.Total</span>
            </header>
            <div class="panel-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">هیچ کاربری یافت نشد.</div>
                }
                else
                {
                    <table class="table table-striped table-hover table-advance">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>نام کامل</th>
                                <th>ایمیل</th>
                                <th>شماره تماس</th>
                                <th>وضعیت</th>
                                <th>آخرین ورود</th>
                                <th>تاریخ عضویت</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@rowNum</td>
                                    <td><strong>@user.FullName</strong></td>
                                    <td>@user.Email</td>
                                    <td>@(user.PhoneNumber ?? "-")</td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="label label-success label-mini">فعال</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger label-mini">غیرفعال</span>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">
                                        @{
                                            string lastLogin = "-";
                                            if (user.LastLoginAt.HasValue) { lastLogin = user.LastLoginAt.Value.ToString("yyyy/MM/dd"); }
                                        }
                                        @lastLogin
                                    </td>
                                    <td style="white-space:nowrap;">@user.CreatedAt.ToString("yyyy/MM/dd")</td>
                                     <td>
                                         <a href="@Url.Action("Edit", "Users", new { area = "Admin", id = user.UserId })" class="btn btn-primary btn-xs" title="ویرایش" style="margin-left: 5px;">
                                             <i class="icon-pencil"></i> ویرایش
                                         </a>
                                         @using (Html.BeginForm("ToggleActive", "Users", new { area = "Admin", id = user.UserId }, FormMethod.Post, new { style = "display:inline;" }))
                                         {
                                             @Html.AntiForgeryToken()
                                             if (user.IsActive)
                                             {
                                                 <button type="submit" class="btn btn-warning btn-xs" title="غیرفعال کردن">
                                                     <i class="icon-ban-circle"></i> غیرفعال
                                                 </button>
                                             }
                                             else
                                             {
                                                 <button type="submit" class="btn btn-success btn-xs" title="فعال کردن">
                                                     <i class="icon-ok"></i> فعال
                                                 </button>
                                             }
                                         }
                                     </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }

                @* Pagination *@
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <div class="text-center">
                        <ul class="pagination pagination-sm">
                            @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                            {
                                <li class="@(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { page = p })">@p</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
