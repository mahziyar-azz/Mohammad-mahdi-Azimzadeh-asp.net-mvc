@model List<Azimzadeh_MVC_project.Models.BlogPost>
@{
    ViewBag.Title = "مدیریت وبلاگ";
}

<div class="row">
    <div class="col-lg-12">
        <section class="panel">
            <header class="panel-heading">
                <i class="icon-book"></i> مدیریت مقالات وبلاگ &nbsp;<span class="badge bg-primary">@ViewBag.Total</span>
                <a href="@Url.Action("Create", "Blog", new { area = "Admin" })" class="btn btn-success btn-sm pull-left" style="margin-top: -4px;">
                    <i class="icon-plus"></i> افزودن مقاله جدید
                </a>
            </header>
            <div class="panel-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info text-center">هیچ مقاله‌ای یافت نشد.</div>
                }
                else
                {
                    <table class="table table-striped table-hover table-advance">
                        <thead>
                            <tr>
                                <th style="width: 5%;">#</th>
                                <th style="width: 10%;">تصویر</th>
                                <th>عنوان</th>
                                <th style="width: 15%;">دسته‌بندی</th>
                                <th style="width: 12%;">نویسنده</th>
                                <th style="width: 10%;">وضعیت</th>
                                <th style="width: 12%;">تاریخ انتشار</th>
                                <th style="width: 18%;">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int rowNum = 1;}
                            @foreach (var post in Model)
                            {
                                string authorName = "ناشناس";
                                if (post.User != null) { authorName = post.User.FullName; }
                                string catName = "-";
                                if (post.BlogCategory != null) { catName = post.BlogCategory.Title; }
                                
                                string coverImg = "/assets/img/blog/default.jpg";
                                if (!string.IsNullOrEmpty(post.ImagePath))
                                {
                                    coverImg = post.ImagePath;
                                }
                                
                                <tr>
                                    <td>@rowNum</td>
                                    <td>
                                        <img src="@coverImg" alt="@post.Title" style="max-height: 40px; max-width: 60px; border-radius: 4px; border: 1px solid #ddd;" />
                                    </td>
                                    <td>
                                        <div style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@post.Title">
                                            <a href="/Home/BlogDetails?id=@post.PostId" target="_blank">@post.Title</a>
                                        </div>
                                    </td>
                                    <td>@catName</td>
                                    <td>@authorName</td>
                                    <td>
                                        @if (post.IsPublished)
                                        {
                                            <span class="label label-success label-mini">منتشر شده</span>
                                        }
                                        else
                                        {
                                            <span class="label label-warning label-mini">پیش‌نویس</span>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">@post.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td style="white-space:nowrap;">
                                        <a href="@Url.Action("Edit", "Blog", new { area = "Admin", id = post.PostId })" class="btn btn-primary btn-xs" title="ویرایش">
                                            <i class="icon-pencil"></i> ویرایش
                                        </a>

                                        @using (Html.BeginForm("TogglePublish", "Blog", new { area = "Admin", id = post.PostId }, FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            if (post.IsPublished)
                                            {
                                                <button type="submit" class="btn btn-warning btn-xs" title="تبدیل به پیش‌نویس">
                                                    <i class="icon-eye-close"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-success btn-xs" title="انتشار">
                                                    <i class="icon-eye-open"></i>
                                                </button>
                                            }
                                        }

                                        @using (Html.BeginForm("Delete", "Blog", new { area = "Admin", id = post.PostId }, FormMethod.Post, new { style = "display:inline;", onsubmit = "return confirm('آیا از حذف این مقاله مطمئن هستید؟ دیدگاه‌های مرتبط نیز حذف خواهند شد.');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-xs" title="حذف">
                                                <i class="icon-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }

                @* Pagination *@
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <div class="text-center">
                        <ul class="pagination pagination-sm">
                            @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                            {
                                <li class="@(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { page = p })">@p</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
