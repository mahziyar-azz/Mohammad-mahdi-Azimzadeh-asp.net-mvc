@model Azimzadeh_MVC_project.Models.BlogPost

<!-- Breadcrumb Start -->
<div class="breadcrumb-area ptb-60 ptb-sm-30">
    <div class="container">
        <div class="breadcrumb">
            <ul>
                <li><a href="/">خانه</a></li>
                <li><a href="/Home/Blog">وبلاگ</a></li>
                <li class="active">@Model.Title</li>
            </ul>
        </div>
    </div>
    <!-- Container End -->
</div>
<!-- Breadcrumb End -->

<!-- وبلاگ Area Start -->
<div class="blog-area pb-60">
    <div class="container">
        <div class="row">
            <!-- Main وبلاگ Start -->
            <div class="col-lg-8">
                <!-- وبلاگ Details Start -->
                <div class="blog-details">
                    <div class="blog-img" style="border-radius: 8px; overflow: hidden; margin-bottom: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                        <img src="@Model.ImagePath" alt="@Model.Title" style="width: 100%; max-height: 450px; object-fit: cover;">
                    </div>
                    <div class="blog-content">
                        <h1 style="font-size: 24px; font-weight: bold; line-height: 1.5; margin-bottom: 15px; color: #222;">@Model.Title</h1>
                        <div class="blog-meta" style="margin-bottom: 25px; font-size: 13px; color: #777; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                            <ul style="list-style: none; padding: 0; margin: 0; display: flex; gap: 20px;">
                                <li><i class="fa fa-user" style="margin-left: 5px;"></i><span>نویسنده: </span> <a href="#" style="color: #333; font-weight: 500;">@(Model.User?.FullName ?? "مدیر وبلاگ")</a></li>
                                <li><i class="fa fa-calendar" style="margin-left: 5px;"></i><span>تاریخ: </span> <a href="#" style="color: #777;">@Model.CreatedAt.ToString("dd MMMM yyyy")</a></li>
                                <li><i class="fa fa-eye" style="margin-left: 5px;"></i><span>بازدید: </span> <a href="#" style="color: #777;">@Model.ViewCount</a></li>
                            </ul>
                        </div>
                        
                        <div class="blog-body-text" style="font-size: 15px; line-height: 1.8; color: #444; text-align: justify; margin-bottom: 30px;">
                            @Html.Raw(Model.Content.Replace("\n", "<br/>"))
                        </div>
                        
                        <!--  وبلاگ-Share Start  -->
                        <div class="blog-share mtb-50" style="background: #f9f9f9; padding: 15px 20px; border-radius: 8px;">
                            <div class="row align-items-center">
                                <div class="col-lg-6 col-md-6 col-sm-6">
                                    <span class="category-text" style="font-weight: bold; margin-left: 10px;">دسته‌بندی: </span>
                                    <a href="/Home/Blog?categoryId=@Model.BlogCategoryId" style="background: #e02c2b; color: #fff; padding: 4px 10px; border-radius: 4px; font-size: 12px; text-decoration: none;">
                                        @(Model.BlogCategory?.Title ?? "بدون دسته‌بندی")
                                    </a>
                                </div>
                                <div class="col-lg-6 col-md-6 col-sm-6">
                                    <div class="social-links text-left" style="display: flex; justify-content: flex-end; align-items: center; gap: 10px;">
                                        <span style="font-weight: bold;">اشتراک‌گذاری:</span>
                                        <a href="#" style="color: #3b5998; font-size: 16px;"><i class="fa fa-facebook"></i></a>
                                        <a href="#" style="color: #1da1f2; font-size: 16px;"><i class="fa fa-twitter"></i></a>
                                        <a href="#" style="color: #0077b5; font-size: 16px;"><i class="fa fa-linkedin"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!--  وبلاگ-Share End  -->
                    </div>
                </div>
                <!-- وبلاگ Details End -->

                <!-- وبلاگ Related Post Start -->
                @if (ViewBag.RecentPosts != null)
                {
                    var recents = (List<Azimzadeh_MVC_project.Models.BlogPost>)ViewBag.RecentPosts;
                    <div class="blog-related-post recent-post mtb-50">
                        <h3 class="sidebar-title" style="font-size: 18px; font-weight: bold; margin-bottom: 20px; border-bottom: 2px solid #e02c2b; padding-bottom: 10px; display: inline-block;">مطالب اخیر دیگر</h3>
                        <div class="row">
                            @foreach (var rPost in recents.Where(p => p.PostId != Model.PostId).Take(3))
                            {
                                <div class="col-md-4 col-sm-6">
                                    <div class="single-blog" style="border: 1px solid #eee; border-radius: 8px; overflow: hidden; margin-bottom: 20px;">
                                        <div class="blog-img" style="position: relative; padding-top: 60%; overflow: hidden;">
                                            <a href="/Home/BlogDetails?id=@rPost.PostId">
                                                <img src="@rPost.ImagePath" alt="@rPost.Title" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                                            </a>
                                        </div>
                                        <div class="blog-content" style="padding: 15px;">
                                            <h4 style="font-size: 14px; font-weight: bold; line-height: 1.5; height: 42px; overflow: hidden; margin-bottom: 10px;">
                                                <a href="/Home/BlogDetails?id=@rPost.PostId" style="color: #333;">@rPost.Title</a>
                                            </h4>
                                            <span style="font-size: 11px; color: #999;">@rPost.CreatedAt.ToString("yyyy-MM-dd")</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                <!-- وبلاگ Related Post End -->

                <!-- Comment Area Start -->
                <div class="comment-area recent-post mt-40">
                    @{
                        var comments = (List<Azimzadeh_MVC_project.Models.Comment>)ViewBag.Comments;
                        var users = (List<Azimzadeh_MVC_project.Models.User>)ViewBag.Users;
                    }
                    <h3 class="sidebar-title" style="font-size: 18px; font-weight: bold; margin-bottom: 20px;">دیدگاه‌ها (@(comments?.Count ?? 0))</h3>
                    
                    @if (comments != null && comments.Any())
                    {
                        foreach (var comm in comments)
                        {
                            <div class="single-comment" style="display: flex; gap: 20px; background: #fafafa; padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #f1f1f1;">
                                <div class="comment-img" style="flex: 0 0 60px; height: 60px; border-radius: 50%; overflow: hidden; background: #eee; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #666;">
                                    <i class="fa fa-user-circle-o"></i>
                                </div>
                                <div class="comment-details">
                                    <h4 style="font-size: 15px; font-weight: bold; margin-bottom: 5px;">@(comm.User?.FullName ?? "کاربر مهمان")</h4>
                                    <span style="font-size: 12px; color: #999;">@comm.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                                    <p style="margin-top: 10px; font-size: 13px; line-height: 1.6; color: #555; white-space: pre-line;">@comm.Content</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p style="color: #888; font-size: 13px;">هنوز هیچ دیدگاهی ثبت نشده است. اولین نفری باشید که نظر می‌دهید!</p>
                    }
                </div>
                <!-- Comment Area End -->

                <!-- Contact Email Area Start -->
                <div class="blog-detail-contact mt-40" style="background: #fff; border: 1px solid #eee; padding: 30px; border-radius: 8px;">
                    <h3 style="font-size: 18px; font-weight: bold; margin-bottom: 15px;">ارسال یک دیدگاه</h3>
                    <p style="font-size: 13px; color: #777; margin-bottom: 25px;">دیدگاه خود را ارسال کنید. نظرات شما به صورت خودکار تایید و منتشر می‌شوند.</p>
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form autocomplete="off" action="/Home/SubmitComment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="targetType" value="Blog" />
                        <input type="hidden" name="targetId" value="@Model.PostId" />
                        
                        <div class="row">
                            <div class="col-md-12 mb-15">
                                <label style="font-weight: bold; display: block; margin-bottom: 8px; font-size: 13px;">ارسال نظر به عنوان کاربر:</label>
                                <select name="userId" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-family: inherit; outline: none; background: #fff;" required>
                                    @if (users != null)
                                    {
                                        foreach (var u in users)
                                        {
                                            <option value="@u.UserId">@u.FullName (@(u.Email.Contains("admin") ? "مدیر" : "کاربر تستی"))</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-12 mb-15">
                                <textarea name="content" placeholder="دیدگاه خود را بنویسید..." style="width: 100%; height: 150px; padding: 15px; border: 1px solid #ddd; border-radius: 6px; font-family: inherit;" required></textarea>
                            </div>
                            <div class="col-md-12">
                                <input type="submit" value="ارسال دیدگاه" style="background: #e02c2b; color: #fff; border: none; padding: 10px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s;">
                            </div>
                        </div>
                    </form>
                </div>
                <!-- Contact Email Area End -->
            </div>
            <!-- Main وبلاگ End -->

            <!-- Sidebar Main وبلاگ Start -->
            <div class="col-lg-4">
                <div class="main-right-sidebar border-default universal-padding" style="background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 25px;">
                    <!-- Recent Post Start -->
                    <div class="recent-post same-sidebar" style="margin-bottom: 40px;">
                        <h3 class="sidebar-title" style="font-size: 16px; font-weight: bold; margin-bottom: 20px; border-bottom: 2px solid #e02c2b; padding-bottom: 8px;">مطالب اخیر</h3>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            @if (ViewBag.RecentPosts != null)
                            {
                                foreach (var rPost in (List<Azimzadeh_MVC_project.Models.BlogPost>)ViewBag.RecentPosts)
                                {
                                    <li class="post-thumb fix" style="display: flex; gap: 15px; margin-bottom: 20px; align-items: center;">
                                        <div class="left-post-thumb" style="flex: 0 0 80px; height: 60px; border-radius: 6px; overflow: hidden; background: #f5f5f5;">
                                            <a href="/Home/BlogDetails?id=@rPost.PostId">
                                                <img class="img" src="@rPost.ImagePath" alt="@rPost.Title" style="width: 100%; height: 100%; object-fit: cover;">
                                            </a>
                                        </div>
                                        <div class="right-post-thumb">
                                            <h4 style="font-size: 13px; font-weight: bold; line-height: 1.4; margin: 0 0 5px 0; height: 36px; overflow: hidden;">
                                                <a href="/Home/BlogDetails?id=@rPost.PostId" style="color: #333;">@rPost.Title</a>
                                            </h4>
                                            <span style="font-size: 11px; color: #999;">@rPost.CreatedAt.ToString("yyyy-MM-dd")</span>
                                        </div>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                    <!-- Recent Post End -->

                    <!-- Category Post Start -->
                    <div class="categorie recent-post same-sidebar" style="margin-bottom: 40px;">
                         <h3 class="sidebar-title" style="font-size: 16px; font-weight: bold; margin-bottom: 20px; border-bottom: 2px solid #e02c2b; padding-bottom: 8px;">دسته‌بندی‌ها</h3>
                         <ul class="categorie-list" style="list-style: none; padding: 0; margin: 0;">
                             @if (ViewBag.Categories != null)
                             {
                                 foreach (var kvp in (List<KeyValuePair<Azimzadeh_MVC_project.Models.BlogCategory, int>>)ViewBag.Categories)
                                 {
                                     var activeClass = ViewBag.SelectedCategoryId == kvp.Key.BlogCategoryId ? "color: #e02c2b; font-weight: bold;" : "color: #555;";
                                     <li style="border-bottom: 1px solid #f9f9f9; padding: 8px 0; display: flex; justify-content: space-between; font-size: 13px;">
                                         <a href="/Home/Blog?categoryId=@kvp.Key.BlogCategoryId" style="@activeClass">@kvp.Key.Title</a>
                                         <span style="color: #999;">(@kvp.Value)</span>
                                     </li>
                                 }
                             }
                         </ul>
                    </div>
                    <!-- Category Post End -->

                    <!-- Tags Start -->
                    <div class="categorie recent-post same-sidebar">
                         <h3 class="sidebar-title" style="font-size: 16px; font-weight: bold; margin-bottom: 20px; border-bottom: 2px solid #e02c2b; padding-bottom: 8px;">برچسب‌های مطلب</h3>
                         <div class="tag-list-wrap" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 15px;">
                             @if (Model.Tags != null && Model.Tags.Any())
                             {
                                 foreach (var tag in Model.Tags)
                                 {
                                     <a href="#" style="background: #f5f5f5; color: #555; font-size: 12px; padding: 5px 10px; border-radius: 4px; border: 1px solid #eee; text-decoration: none;"># @tag.Title</a>
                                 }
                             }
                             else
                             {
                                 <span style="font-size: 12px; color: #999;">بدون برچسب</span>
                             }
                         </div>
                    </div>
                    <!-- Tags End -->
                </div>
            </div>
            <!-- Sidebar Main وبلاگ End -->
        </div>
    </div>
    <!-- Container End -->
</div>
<!-- وبلاگ Area End -->