@model Azimzadeh_MVC_project.Models.Cart
@{
    var user = ViewBag.User as Azimzadeh_MVC_project.Models.User;
    var address = ViewBag.UserAddress as Azimzadeh_MVC_project.Models.UserAddress;
    decimal subtotal = Model != null ? Model.CartItems.Sum(ci => ci.Quantity * ci.UnitPrice) : 0;
}
        <!-- Breadcrumb Start -->
        <div class="breadcrumb-area pt-60 pb-55 pt-sm-30 pb-sm-20">
            <div class="container">
                <div class="breadcrumb">
                    <ul>
                        <li><a href="/">خانه</a></li>
                        <li class="active"><a href="/Home/Checkout">تسویه حساب</a></li>
                    </ul>
                </div>
            </div>
            <!-- Container End -->
        </div>
        <!-- Breadcrumb End -->
        <!-- coupon-area start -->
        <div class="coupon-area">
            <div class="container">
               <!-- Section Title Start -->
                <div class="section-title mb-20">
                    <h2>تسویه حساب</h2>
                </div>
                <!-- Section Title Start End -->
            </div>
        </div>
        <!-- coupon-area end -->
        <!-- checkout-area start -->
        <div class="checkout-area pt-30  pb-60">
            <div class="container">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
                <form action="/Home/SubmitOrder" method="post">                
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-lg-6 col-md-6">
                            <div class="checkbox-form">
                                <h3>جزئیات پرداخت و ارسال سفارش</h3>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="checkout-form-list">
                                            <label>نام <span class="required">*</span></label>
                                            <input type="text" name="firstName" value="@(user != null ? user.FirstName : "")" required="required" placeholder="نام" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="checkout-form-list mb-30">
                                            <label>نام خانوادگی <span class="required">*</span></label>
                                            <input type="text" name="lastName" value="@(user != null ? user.LastName : "")" required="required" placeholder="نام خانوادگی" />
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="checkout-form-list mb-30">
                                            <label>استان <span class="required">*</span></label>
                                            <input type="text" name="province" value="@(address != null ? address.Province : "")" required="required" placeholder="مثلا: تهران" />
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="checkout-form-list mb-30">
                                            <label>شهر <span class="required">*</span></label>
                                            <input type="text" name="city" value="@(address != null ? address.City : "")" required="required" placeholder="مثلا: تهران" />
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="checkout-form-list mb-30">
                                            <label>آدرس پستی کامل <span class="required">*</span></label>
                                            <input type="text" name="fullAddress" value="@(address != null ? address.FullAddress : "")" required="required" placeholder="آدرس خیابان، کوچه، پلاک، واحد" />
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="checkout-form-list mb-30">
                                            <label>کد پستی <span class="required">*</span></label>
                                            <input type="text" name="postalCode" value="@(address != null ? address.PostalCode : "")" required="required" placeholder="کد پستی ۱۰ رقمی" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="checkout-form-list mb-30">
                                            <label>آدرس ایمیل <span class="required">*</span></label>
                                            <input type="email" name="email" value="@(user != null ? user.Email : "")" required="required" placeholder="email@example.com" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="checkout-form-list mb-30">
                                            <label>تلفن همراه <span class="required">*</span></label>
                                            <input type="text" name="phone" value="@(user != null ? user.PhoneNumber : "")" required="required" placeholder="تلفن همراه" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6">
                            <div class="your-order">
                                <h3>سفارش شما</h3>
                                <div class="your-order-table table-responsive">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th class="product-name">محصول</th>
                                                <th class="product-مجموع">مجموع</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model != null && Model.CartItems != null)
                                            {
                                                foreach (var item in Model.CartItems)
                                                {
                                                    <tr class="cart_item">
                                                        <td class="product-name">
                                                            @item.Product.Title <strong class="product-quantity"> × @item.Quantity</strong>
                                                        </td>
                                                        <td class="product-مجموع">
                                                            <span class="amount">@((item.Quantity * item.UnitPrice).ToString("N0")) ریال</span>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="cart-subtotal">
                                                <th>جمع جزء سبد خرید</th>
                                                <td><span class="amount">@subtotal.ToString("N0") ریال</span></td>
                                            </tr>
                                            <tr class="order-total">
                                                <th>جمع کل سفارش</th>
                                                <td><strong><span class="amount">@subtotal.ToString("N0") ریال</span></strong>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <div class="payment-method">
                                    <div class="payment-accordion">
                                        <div class="panel-group" id="accordion" role="tablist" aria-multiselectable="true">
                                            <div class="panel panel-default">
                                                <div class="panel-heading" role="tab" id="headingOne">
                                                    <h4 class="panel-title">
                                                        <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                                     پرداخت در محل
                                                     </a>
                                                    </h4>
                                                </div>
                                                <div id="collapseOne" class="panel-collapse collapse in show" role="tabpanel" aria-labelledby="headingOne">
                                                    <div class="panel-body">
                                                        <p>مبلغ سفارش را در زمان تحویل کالا به مامور پست پرداخت نمایید. (سرویس پرداخت در محل)</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="order-button-payment">
                                            <input type="submit" value="ثبت سفارش" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                 </form>   
            </div>
        </div>
        <!-- checkout-area end -->
        <!-- Brand Logo Start -->
        <div class="brand-area pb-60">
            <div class="container">
                <!-- Brand Banner Start -->
                <div class="brand-banner owl-carousel">
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                </div>
                <!-- Brand Banner End -->                
            </div>
        </div>
        <!-- Brand Logo End -->

        