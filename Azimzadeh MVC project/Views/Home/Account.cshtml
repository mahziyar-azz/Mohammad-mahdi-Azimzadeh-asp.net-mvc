@model Azimzadeh_MVC_project.Models.User
        <!-- Breadcrumb Start -->
        <div class="breadcrumb-area ptb-60 ptb-sm-30">
            <div class="container">
                <div class="breadcrumb">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li class="active"><a href="/Home/Account">حساب کاربری</a></li>
                    </ul>
                </div>
            </div>
            <!-- Container End -->
        </div>
        <!-- Breadcrumb End -->
        <!-- My حساب کاربری Start Here -->
        <div class="my-account white-bg pb-60">
            <div class="container">
                <div class="account-dashboard">
                   <div class="dashboard-upper-info">
                       <div class="row no-gutters align-items-center">
                           <div class="col-lg-3 col-md-6">
                               <div class="d-single-info">
                                   <p class="user-name">سلام <span>@(Model != null ? Model.FullName : "کاربر")</span></p>
                                   <p>(شما نیستید؟ <a href="/Home/Logout">خروج</a>)</p>
                               </div>
                           </div>
                           <div class="col-lg-3 col-md-6">
                               <div class="d-single-info">
                                   <p>نیاز به راهنمایی دارید؟ پشتیبانی مشتریان:</p>
                                   <p>admin@site.com</p>
                               </div>
                           </div>
                           <div class="col-lg-3 col-md-6">
                               <div class="d-single-info">
                                   <p>پشتیبانی ایمیل:</p>
                                   <p>support@site.com</p>
                               </div>
                           </div>
                           <div class="col-lg-3 col-md-6">
                               <div class="d-single-info text-center">
                                   <a class="view-cart" href="/Home/Cart"><i class="fa fa-cart-plus" aria-hidden="true"></i>مشاهده سبد خرید</a>
                               </div>
                           </div>
                       </div>
                   </div>
                    <div class="row">
                        <div class="col-lg-2">
                            <!-- Nav tabs -->
                            <ul class="nav flex-column dashboard-list" role="tablist">
                                <li><a class="active" data-toggle="tab" href="#dashboard">داشبورد</a></li>
                                <li><a data-toggle="tab" href="#orders">سفارش‌ها</a></li>
                                <li><a data-toggle="tab" href="#downloads">دانلودها</a></li>
                                <li><a data-toggle="tab" href="#addresses">آدرس‌ها</a></li>
                                <li><a data-toggle="tab" href="#account-details">جزئیات حساب کاربری</a></li>
                                <li><a href="/Home/Logout">خروج</a></li>
                            </ul>
                        </div>
                        <div class="col-lg-10">
                            <!-- Tab panes -->
                            <div class="tab-content dashboard-content mt-all-40">
                                @if (TempData["ErrorMessage"] != null)
                                {
                                    <div class="alert alert-danger" style="margin-bottom: 20px;">@TempData["ErrorMessage"]</div>
                                }
                                @if (TempData["SuccessMessage"] != null)
                                {
                                    <div class="alert alert-success" style="margin-bottom: 20px;">@TempData["SuccessMessage"]</div>
                                }
                                <div id="dashboard" class="tab-pane active">
                                    <h3>داشبورد </h3>
                                    <p>از طریق داشبورد حساب کاربری خود می‌توانید به راحتی <a href="#orders" onclick="jQuery('ul.dashboard-list a[href=\'#orders\']').tab('show'); return false;">سفارش‌های اخیر</a> را بررسی و مشاهده کنید، <a href="#addresses" onclick="jQuery('ul.dashboard-list a[href=\'#addresses\']').tab('show'); return false;">آدرس‌های ارسال و پرداخت</a> خود را مدیریت کنید و <a href="#account-details" onclick="jQuery('ul.dashboard-list a[href=\'#account-details\']').tab('show'); return false;">رمز عبور و جزئیات حساب خود را ویرایش کنید</a>.</p>
                                </div>
                                <div id="orders" class="tab-pane fade">
                                    <h3>سفارش‌ها</h3>
                                    @if (Model != null && Model.Orders != null && Model.Orders.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>سفارش</th>
                                                        <th>تاریخ</th>
                                                        <th>وضعیت</th>
                                                        <th>مجموع</th>
                                                        <th>عملیات</th>	 	 	 	
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var order in Model.Orders.OrderByDescending(o => o.CreatedAt))
                                                    {
                                                        <tr>
                                                            <td>@order.OrderId</td>
                                                            <td>@order.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                                            <td>
                                                                @if (order.OrderStatus == "Completed" || order.OrderStatus == "تحویل داده شده" || order.OrderStatus == "تکمیل شده")
                                                                {
                                                                    <span class="label label-success" style="padding: 2px 8px; border-radius: 4px; font-size: 11px;">تکمیل شده</span>
                                                                }
                                                                else if (order.OrderStatus == "Cancelled" || order.OrderStatus == "لغو شده")
                                                                {
                                                                    <span class="label label-danger" style="padding: 2px 8px; border-radius: 4px; font-size: 11px;">لغو شده</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="label label-warning" style="padding: 2px 8px; border-radius: 4px; font-size: 11px; color: #000;">@(string.IsNullOrEmpty(order.OrderStatus) ? "در حال بررسی" : order.OrderStatus)</span>
                                                                }
                                                            </td>
                                                            <td>@order.TotalAmount.ToString("N0") ریال</td>
                                                            <td>
                                                                <a class="view btn btn-default btn-xs" href="/Home/OrderSuccess?id=@order.OrderId">مشاهده فاکتور</a>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted" style="margin: 20px 0;">شما هنوز هیچ سفارشی ثبت نکرده‌اید.</p>
                                    }
                                </div>
                                <div id="downloads" class="tab-pane fade">
                                    <h3>دانلودها</h3>
                                    <div class="table-responsive">
                                        <table class="table">
                                            <thead>
                                                <tr>
                                                    <th>محصول</th>
                                                    <th>دانلودها</th>
                                                    <th>تاریخ انقضا</th>
                                                    <th>دانلود</th>	 	 	 	
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>نام محصول در اینجا</td>
                                                    <td>۱۰ مه ۲۰۱۸</td>
                                                    <td>هرگز</td>
                                                    <td><a class="view" href="#">برای دانلود فایل کلیک کنید</a></td>
                                                </tr>
                                                <tr>
                                                    <td>نام محصول در اینجا</td>
                                                    <td>۱۱ سپتامبر ۲۰۱۸</td>
                                                    <td>هرگز</td>
                                                    <td><a class="view" href="#">برای دانلود فایل کلیک کنید</a></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div id="addresses" class="tab-pane fade">
                                    <h3>آدرس‌ها</h3>
                                    <p class="mb-20">آدرس‌های زیر به صورت پیش‌فرض در صفحه تسویه حساب استفاده خواهند شد.</p>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="address-box" style="border: 1px solid #e2e8f0; padding: 20px; border-radius: 8px; background-color: #fafafa; position: relative;">
                                                <h4 class="billing-address" style="margin-top: 0; color: #ff9800; font-family: 'yekan', sans-serif;">آدرس پیش‌فرض ارسال و پرداخت</h4>
                                                <a class="view" href="#account-details" onclick="jQuery('ul.dashboard-list a[href=\'#account-details\']').tab('show'); return false;" style="position: absolute; top: 20px; left: 20px; color: #ff9800; font-weight: bold;"><i class="fa fa-edit"></i> ویرایش</a>
                                                
                                                @if (Model != null && (!string.IsNullOrEmpty(Model.Address1) || !string.IsNullOrEmpty(Model.Address2)))
                                                {
                                                    <p style="margin-bottom: 8px;"><strong>تحویل‌گیرنده:</strong> @Model.FullName</p>
                                                    if (!string.IsNullOrEmpty(Model.Address1))
                                                    {
                                                        <p style="margin-bottom: 8px;"><strong>آدرس اصلی (۱):</strong> @Model.Address1</p>
                                                    }
                                                    if (!string.IsNullOrEmpty(Model.Address2))
                                                    {
                                                        <p style="margin-bottom: 8px;"><strong>آدرس فرعی (۲):</strong> @Model.Address2</p>
                                                    }
                                                    <p style="margin-bottom: 0;"><strong>شماره تماس:</strong> @(string.IsNullOrEmpty(Model.PhoneNumber) ? "-" : Model.PhoneNumber) @(string.IsNullOrEmpty(Model.HomePhoneNumber) ? "" : $" / {Model.HomePhoneNumber}")</p>
                                                }
                                                else
                                                {
                                                    <p class="text-muted" style="margin: 15px 0;">هیچ آدرسی ثبت نشده است.</p>
                                                    <a class="btn btn-warning btn-xs" href="#account-details" onclick="jQuery('ul.dashboard-list a[href=\'#account-details\']').tab('show'); return false;">ثبت اولین آدرس</a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div id="account-details" class="tab-pane fade">
                                     <h3>جزئیات حساب کاربری </h3>
                                     @{
                                         string homePhoneCountry = "";
                                         string homePhoneBody = "";
                                         if (Model != null && !string.IsNullOrEmpty(Model.HomePhoneNumber))
                                         {
                                             var parts = Model.HomePhoneNumber.Split('-');
                                             if (parts.Length == 2)
                                             {
                                                 homePhoneCountry = parts[0].Replace("+", "").Trim();
                                                 homePhoneBody = parts[1].Trim();
                                             }
                                         }
                                     }
                                     <div class="register-form login-form clearfix">
                                         <form action="/Home/UpdateProfile" method="post">
                                             @Html.AntiForgeryToken()
                                             <div class="form-group row">
                                                 <label for="gender" class="col-lg-3 col-md-4 col-form-label">جنسیت</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <select name="gender" id="gender" class="form-control" style="height: auto; padding: 10px;">
                                                         <option value="آقا" @(Model != null && Model.Gender == "آقا" ? "selected" : "")>آقای.</option>
                                                         <option value="خانم" @(Model != null && Model.Gender == "خانم" ? "selected" : "")>خانم.</option>
                                                         <option value="سایر" @(Model != null && Model.Gender == "سایر" ? "selected" : "")>سایر</option>
                                                     </select>
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="firstName" class="col-lg-3 col-md-4 col-form-label">نام</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="firstName" class="form-control" id="firstName" value="@(Model != null ? Model.FirstName : "")" required="required">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="lastName" class="col-lg-3 col-md-4 col-form-label">نام خانوادگی</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="lastName" class="form-control" id="lastName" value="@(Model != null ? Model.LastName : "")" required="required">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="email" class="col-lg-3 col-md-4 col-form-label">آدرس ایمیل</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="email" name="email" class="form-control" id="email" value="@(Model != null ? Model.Email : "")" readonly="readonly">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="phone" class="col-lg-3 col-md-4 col-form-label">شماره همراه</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="phone" class="form-control" id="phone" value="@(Model != null ? Model.PhoneNumber : "")">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="homePhoneCountry" class="col-lg-3 col-md-4 col-form-label">تلفن ثابت</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <div style="display: flex; align-items: center; direction: ltr;">
                                                         <span style="margin-right: 5px; font-weight: bold;">+</span>
                                                         <input type="text" name="homePhoneCountry" class="form-control" style="width: 70px; text-align: center;" placeholder="98" maxlength="3" value="@homePhoneCountry">
                                                         <span style="margin: 0 10px;">-</span>
                                                         <input type="text" name="homePhoneBody" class="form-control" style="flex: 1;" placeholder="12345678" maxlength="8" value="@homePhoneBody">
                                                     </div>
                                                     <small class="form-text text-muted" style="margin-top: 5px; direction: rtl; text-align: right;">فرمت: {+کد کشور - شماره ۸ رقمی}</small>
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="address1" class="col-lg-3 col-md-4 col-form-label">آدرس ۱</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="address1" class="form-control" id="address1" value="@(Model != null ? Model.Address1 : "")" placeholder="آدرس اصلی خود را وارد کنید...">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="address2" class="col-lg-3 col-md-4 col-form-label">آدرس ۲</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="address2" class="form-control" id="address2" value="@(Model != null ? Model.Address2 : "")" placeholder="آدرس فرعی (اختیاری)">
                                                 </div>
                                             </div>
                                             <hr style="margin: 30px 0; border-top: 1px dashed #e2e8f0;" />
                                             <h4 class="mb-20">اطلاعات پرداخت و بانکی</h4>
                                             <div class="form-group row">
                                                 <label for="cardNumber" class="col-lg-3 col-md-4 col-form-label">شماره کارت بانکی (۱۶ رقمی)</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="cardNumber" class="form-control" id="cardNumber" placeholder="1234567812345678" value="@(Model != null ? Model.CardNumber : "")" maxlength="16">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="cvv" class="col-lg-3 col-md-4 col-form-label">کد CVV2</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="cvv" class="form-control" id="cvv" placeholder="123" value="@(Model != null ? Model.CVV : "")" maxlength="4">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="expirationDate" class="col-lg-3 col-md-4 col-form-label">تاریخ انقضا (MM/YY)</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="text" name="expirationDate" class="form-control" id="expirationDate" placeholder="08/29" value="@(Model != null ? Model.ExpirationDate : "")" maxlength="5">
                                                 </div>
                                             </div>
                                             <hr style="margin: 30px 0; border-top: 1px dashed #e2e8f0;" />
                                             <h4 class="mb-20">تغییر رمز عبور (اختیاری)</h4>
                                             <div class="form-group row">
                                                 <label for="inputpassword" class="col-lg-3 col-md-4 col-form-label">رمز عبور فعلی</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="password" name="currentPassword" class="form-control" id="inputpassword" placeholder="برای تغییر رمز عبور الزامی است">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="newpassword" class="col-lg-3 col-md-4 col-form-label">رمز عبور جدید</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="password" name="newPassword" class="form-control" id="newpassword" placeholder="رمز عبور جدید">
                                                 </div>
                                             </div>
                                             <div class="form-group row">
                                                 <label for="c-password" class="col-lg-3 col-md-4 col-form-label">تکرار رمز عبور</label>
                                                 <div class="col-lg-6 col-md-8">
                                                     <input type="password" name="confirmPassword" class="form-control" id="c-password" placeholder="تکرار رمز عبور جدید">
                                                 </div>
                                             </div>
                                             <div class="register-box mt-40">
                                                 <button type="submit" class="return-customer-btn f-right">ذخیره تغییرات</button>
                                             </div>
                                         </form>
                                     </div>
                                 </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- My حساب کاربری End Here -->
        <!-- Brand Logo Start -->
        <div class="brand-area pb-60">
            <div class="container">
                <!-- Brand Banner Start -->
                <div class="brand-banner owl-carousel">
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                </div>
                <!-- Brand Banner End -->                
            </div>
        </div>
        <!-- Brand Logo End -->