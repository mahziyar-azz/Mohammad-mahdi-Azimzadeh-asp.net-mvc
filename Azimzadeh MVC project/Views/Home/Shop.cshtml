                            <div class="tab-content fix">
                                <div id="grid-view" class="tab-pane ">
                                    <div class="row">
                                        @foreach (var product in Model)
                                        {
                                            var mainImage = product.ProductImages.FirstOrDefault(img => img.IsMain) ?? product.ProductImages.FirstOrDefault();
                                            var mainImagePath = mainImage != null ? mainImage.ImagePath : "/assets/img/products/1.jpg";
                                            var hoverImage = product.ProductImages.FirstOrDefault(img => !img.IsMain) ?? mainImage;
                                            var hoverImagePath = hoverImage != null ? hoverImage.ImagePath : mainImagePath;

                                            <!-- Single Product Start -->
                                            <div class="col-lg-4 col-sm-6">
                                                <div class="single-product">
                                                    <!-- Product Image Start -->
                                                    <div class="pro-img">
                                                        <a href="/Home/Product?id=@product.ProductId">
                                                            <img class="primary-img" src="@mainImagePath" alt="@product.Title">
                                                            <img class="secondary-img" src="@hoverImagePath" alt="@product.Title">
                                                        </a>
                                                    </div>
                                                    <!-- Product Image End -->
                                                    <!-- Product Content Start -->
                                                    <div class="pro-content">
                                                        <div class="product-rating">
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                        </div>                                
                                                        <h4><a href="/Home/Product?id=@product.ProductId">@product.Title</a></h4>
                                                        <p>
                                                            @if (product.DiscountPrice.HasValue)
                                                            {
                                                                <span class="price">@product.DiscountPrice.Value.ToString("N0") ریال</span>
                                                                <del class="prev-price">@product.Price.ToString("N0") ریال</del>
                                                            }
                                                            else
                                                            {
                                                                <span class="price">@product.Price.ToString("N0") ریال</span>
                                                            }
                                                        </p>
                                                        <div class="pro-actions">
                                                            <div class="actions-secondary">
                                                                <a href="/Home/Wishlist" data-toggle="tooltip" title="افزودن به علاقه‌مندی‌ها"><i class="fa fa-heart"></i></a>
                                                                <a class="add-cart" href="/Home/Cart" data-toggle="tooltip" title="افزودن به سبد خرید">افزودن به سبد خرید</a>
                                                                <a href="/Home/Compare" data-toggle="tooltip" title="افزودن به مقایسه"><i class="fa fa-signal"></i></a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- Product Content End -->
                                                    @if (product.DiscountPrice.HasValue)
                                                    {
                                                        var discountPercent = (int)Math.Round((double)(product.Price - product.DiscountPrice.Value) / (double)product.Price * 100);
                                                        <span class="sticker-new">-@discountPercent%</span>
                                                    }
                                                </div>
                                            </div>
                                            <!-- Single Product End -->
                                        }
                                    </div>                                    
                                </div>
                                <!-- #grid view End -->
                                <div id="list-view" class="tab-pane active">
                                            </a>
