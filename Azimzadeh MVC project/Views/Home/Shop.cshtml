                    <!-- Product Categorie List Start -->
                    <div class="col-lg-9 order-1 order-lg-2">
                        <!-- Grid & List View Start -->
                        <div class="grid-list-top border-default universal-padding fix mb-30">
                            <div class="grid-list-view f-left">
                                <ul class="list-inline nav">
                                    <li><a data-toggle="tab" href="#grid-view"><i class="fa fa-th"></i></a></li>
                                    <li><a  class="active" data-toggle="tab" href="#list-view"><i class="fa fa-list-ul"></i></a></li>
                                    <li><span class="grid-item-list"> نمایش @Model.Count() از @Model.Count() آیتم</span></li>
                                </ul>
                            </div>
                            <!-- Toolbar Short Area Start -->
                            <div class="main-toolbar-sorter f-right">
                                <div class="toolbar-sorter">
                                    <label>مرتب‌سازی بر اساس</label>
                                    <select class="sorter" name="sorter">
                                        <option value="Position" selected="selected">موقعیت</option>
                                        <option value="Product Name">نام محصول</option>
                                        <option value="Price">قیمت</option>
                                    </select>
                                    <span><a href="#"><i class="fa fa-arrow-up"></i></a></span>
                                </div>
                            </div>
                            <!-- Toolbar Short Area End -->
                        </div>
                        <!-- Grid & List View End -->
                        <div class="main-categorie">
                            <!-- Grid & List Main Area End -->
                            <div class="tab-content fix">
                                <div id="grid-view" class="tab-pane ">
                                    <div class="row">
                                        @foreach (var product in Model)
                                        {
                                            var mainImage = product.ProductImages.FirstOrDefault(img => img.IsMain) ?? product.ProductImages.FirstOrDefault();
                                            var mainImagePath = mainImage != null ? mainImage.ImagePath : "/assets/img/products/1.jpg";
                                            var hoverImage = product.ProductImages.FirstOrDefault(img => !img.IsMain) ?? mainImage;
                                            var hoverImagePath = hoverImage != null ? hoverImage.ImagePath : mainImagePath;

                                            <!-- Single Product Start -->
                                            <div class="col-lg-4 col-sm-6">
                                                <div class="single-product">
                                                    <!-- Product Image Start -->
                                                    <div class="pro-img">
                                                        <a href="/Home/Product?id=@product.ProductId">
                                                            <img class="primary-img" src="@mainImagePath" alt="@product.Title">
                                                            <img class="secondary-img" src="@hoverImagePath" alt="@product.Title">
                                                        </a>
                                                    </div>
                                                    <!-- Product Image End -->
                                                    <!-- Product Content Start -->
                                                    <div class="pro-content">
                                                        <div class="product-rating">
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                            <i class="fa fa-star"></i>
                                                        </div>                                
                                                        <h4><a href="/Home/Product?id=@product.ProductId">@product.Title</a></h4>
                                                        <p>
                                                            @if (product.DiscountPrice.HasValue)
                                                            {
                                                                <span class="price">@product.DiscountPrice.Value.ToString("N0") ریال</span>
                                                                <del class="prev-price">@product.Price.ToString("N0") ریال</del>
                                                            }
                                                            else
                                                            {
                                                                <span class="price">@product.Price.ToString("N0") ریال</span>
                                                            }
                                                        </p>
                                                        <div class="pro-actions">
                                                            <div class="actions-secondary">
                                                                <a href="/Home/Wishlist" data-toggle="tooltip" title="افزودن به علاقه‌مندی‌ها"><i class="fa fa-heart"></i></a>
                                                                <a class="add-cart" href="/Home/Cart" data-toggle="tooltip" title="افزودن به سبد خرید">افزودن به سبد خرید</a>
                                                                <a href="/Home/Compare" data-toggle="tooltip" title="افزودن به مقایسه"><i class="fa fa-signal"></i></a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- Product Content End -->
                                                    @if (product.DiscountPrice.HasValue)
                                                    {
                                                        var discountPercent = (int)Math.Round((double)(product.Price - product.DiscountPrice.Value) / (double)product.Price * 100);
                                                        <span class="sticker-new">-@discountPercent%</span>
                                                    }
                                                </div>
                                            </div>
                                            <!-- Single Product End -->
                                        }
                                    </div>                                    
                                </div>
                                 <!-- #grid view End -->
                                <div id="list-view" class="tab-pane active">
                                    @foreach (var product in Model)
                                    {
                                        var mainImage = product.ProductImages.FirstOrDefault(img => img.IsMain) ?? product.ProductImages.FirstOrDefault();
                                        var mainImagePath = mainImage != null ? mainImage.ImagePath : "/assets/img/products/1.jpg";
                                        var hoverImage = product.ProductImages.FirstOrDefault(img => !img.IsMain) ?? mainImage;
                                        var hoverImagePath = hoverImage != null ? hoverImage.ImagePath : mainImagePath;

                                        <!-- Single Product Start -->
                                        <div class="single-product" style="display: flex; margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 30px;">
                                            <!-- Product Image Start -->
                                            <div class="pro-img" style="flex: 0 0 250px; margin-left: 20px;">
                                                <a href="/Home/Product?id=@product.ProductId">
                                                    <img class="primary-img" src="@mainImagePath" alt="@product.Title" style="max-width: 100%;">
                                                    <img class="secondary-img" src="@hoverImagePath" alt="@product.Title" style="max-width: 100%;">
                                                </a>
                                            </div>
                                            <!-- Product Image End -->
                                            <!-- Product Content Start -->
                                            <div class="pro-content" style="flex: 1;">
                                                <div class="product-rating">
                                                    <i class="fa fa-star"></i>
                                                    <i class="fa fa-star"></i>
                                                    <i class="fa fa-star"></i>
                                                    <i class="fa fa-star"></i>
                                                    <i class="fa fa-star"></i>
                                                </div>                                
                                                <h4><a href="/Home/Product?id=@product.ProductId" style="font-size: 18px; font-weight: bold;">@product.Title</a></h4>
                                                <p style="margin-top: 10px;">
                                                    @if (product.DiscountPrice.HasValue)
                                                    {
                                                        <span class="price" style="font-size: 16px; font-weight: bold; color: #ff5e14; margin-left: 10px;">@product.DiscountPrice.Value.ToString("N0") ریال</span>
                                                        <del class="prev-price" style="color: #999;">@product.Price.ToString("N0") ریال</del>
                                                    }
                                                    else
                                                    {
                                                        <span class="price" style="font-size: 16px; font-weight: bold; color: #222;">@product.Price.ToString("N0") ریال</span>
                                                    }
                                                </p>
                                                <p style="margin-top: 15px; color: #666; line-height: 1.8;">@product.ShortDescription</p>
                                                <div class="pro-actions" style="margin-top: 20px;">
                                                    <div class="actions-secondary">
                                                        <a href="/Home/Wishlist" data-toggle="tooltip" title="افزودن به علاقه‌مندی‌ها" style="margin-left: 10px;"><i class="fa fa-heart"></i></a>
                                                        <a class="add-cart" href="/Home/Cart" data-toggle="tooltip" title="افزودن به سبد خرید" style="background: #333; color: #fff; padding: 8px 15px; border-radius: 4px; text-decoration: none;">افزودن به سبد خرید</a>
                                                        <a href="/Home/Compare" data-toggle="tooltip" title="افزودن به مقایسه" style="margin-right: 10px;"><i class="fa fa-signal"></i></a>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- Product Content End -->
                                        </div>
                                        <!-- Single Product End -->
                                    }
                                </div>
                                 <!-- #list view End -->
                            </div>
                            <!-- Grid & List Main Area End -->
                        </div>
