                            <div class="single-sidebar">
                                <div class="group-title">
                                    <h2>دسته‌بندی‌ها</h2>
                                </div>
                                <ul>
                                    @if (ViewBag.SelectedCategoryId != null || ViewBag.SelectedTagId != null)
                                    {
                                        <li class="mb-2"><a href="/Home/Shop" class="text-danger font-weight-bold"><i class="fa fa-times-circle"></i> حذف فیلترها</a></li>
                                    }
                                    @if (ViewBag.Categories != null)
                                    {
                                        foreach (var kvp in (List<KeyValuePair<Azimzadeh_MVC_project.Models.Category, int>>)ViewBag.Categories)
                                        {
                                            var activeClass = ViewBag.SelectedCategoryId == kvp.Key.CategoryId ? "font-weight-bold text-primary" : "";
                                            <li>
                                                <a class="@activeClass" href="/Home/Shop?categoryId=@kvp.Key.CategoryId">
                                                    @kvp.Key.Title (@kvp.Value)
                                                </a>
                                            </li>
                                        }
                                    }
                                </ul>
