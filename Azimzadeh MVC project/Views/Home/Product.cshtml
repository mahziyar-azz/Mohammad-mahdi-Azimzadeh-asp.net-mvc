@model Azimzadeh_MVC_project.Models.Product

        <!-- Breadcrumb Start -->
        <div class="breadcrumb-area ptb-60 ptb-sm-30">
            <div class="container">
                <div class="breadcrumb">
                    <ul>
                        <li><a href="/">خانه</a></li>
                        <li><a href="/Home/Shop">فروشگاه</a></li>
                        @if (Model.Category != null)
                        {
                            <li><a href="/Home/Shop?categoryId=@Model.CategoryId">@Model.Category.Title</a></li>
                        }
                        <li class="active"><a href="/Home/Product?id=@Model.ProductId">@Model.Title</a></li>
                    </ul>
                </div>
            </div>
            <!-- Container End -->
        </div>
        <!-- Breadcrumb End -->
        <!-- Product Thumbnail Start -->
        <div class="main-product-thumbnail pb-60">
            <div class="container">
                <div class="row">
                    <!-- Main Thumbnail Image Start -->
                    <div class="col-lg-5" style="position: relative;">
                        <!-- Thumbnail Large Image start -->
                        <div class="tab-content">
                            @{
                                var images = Model.ProductImages.OrderBy(img => img.DisplayOrder).ToList();
                                if (!images.Any())
                                {
                                    images.Add(new Azimzadeh_MVC_project.Models.ProductImage { ImagePath = "/assets/img/products/1.jpg", IsMain = true });
                                }
                            }
                            @for (int i = 0; i < images.Count; i++)
                            {
                                var img = images[i];
                                var activeClass = i == 0 ? "active" : "";
                                <div id="thumb@(i + 1)" class="tab-pane @activeClass">
                                    <a data-fancybox="images" href="@img.ImagePath"><img src="@img.ImagePath" alt="@Model.Title"></a>
                                </div>
                            }
                        </div>
                        <!-- Thumbnail Large Image End -->
                        @if (Model.DiscountPrice.HasValue)
                        {
                            var discountPercent = (int)Math.Round((double)(Model.Price - Model.DiscountPrice.Value) / (double)Model.Price * 100);
                            <span class="sticker-new" style="position: absolute; top: 15px; right: 25px; background: #ff5e14; color: #fff; padding: 5px 10px; font-weight: bold; border-radius: 4px; z-index: 10; font-size: 13px;">-@discountPercent%</span>
                        }

                        <!-- Thumbnail Image End -->
                        <div class="product-thumbnail">
                            <div class="thumb-menu nav">
                                @for (int i = 0; i < images.Count; i++)
                                {
                                    var img = images[i];
                                    var activeClass = i == 0 ? "active" : "";
                                    <a class="@activeClass" data-toggle="tab" href="#thumb@(i + 1)"> <img src="@img.ImagePath" alt="@Model.Title"></a>
                                }
                            </div>
                        </div>
                        <!-- Thumbnail image end -->
                    </div>
                    <!-- Main Thumbnail Image End -->
                    <!-- Thumbnail Description Start -->
                    <div class="col-lg-7">
                        <div class="thubnail-desc fix">
                            <h3 class="product-header">@Model.Title</h3>
                            <div class="rating-summary fix mtb-10">
                                <div class="rating f-left">
                                    <i class="fa fa-star"></i>
                                    <i class="fa fa-star"></i>
                                    <i class="fa fa-star"></i>
                                    <i class="fa fa-star"></i>
                                    <i class="fa fa-star"></i>
                                </div>
                                <div class="rating-feedback f-left">
                                    <a href="#">(۵ نظر)</a>
                                    <a href="#">ثبت نظر برای این محصول</a>
                                </div>
                            </div>
                            <div class="pro-price mb-10">
                                <p>
                                    @if (Model.DiscountPrice.HasValue)
                                    {
                                        <span class="price">@Model.DiscountPrice.Value.ToString("N0") ریال</span>
                                        <del class="prev-price">@Model.Price.ToString("N0") ریال</del>
                                    }
                                    else
                                    {
                                        <span class="price">@Model.Price.ToString("N0") ریال</span>
                                    }
                                </p>
                            </div>
                            <div class="pro-ref mb-15">
                                <p>
                                    @if (Model.StockQuantity > 0)
                                    {
                                        <span class="in-stock">موجود در انبار (@Model.StockQuantity عدد)</span>
                                    }
                                    else
                                    {
                                        <span class="out-stock text-danger" style="font-weight: bold; margin-left: 10px;">ناموجود</span>
                                    }
                                    <span class="sku">شناسه محصول (SKU): @Model.SKU</span>
                                </p>
                            </div>
                             <div class="box-quantity">
                                 <form action="#" style="display: flex; align-items: center; gap: 15px;">
                                     <input class="number" id="numeric" type="number" min="1" value="1" style="margin: 0;">
                                     <a class="add-cart" href="/Home/Cart" style="margin: 0; float: none; display: inline-block; vertical-align: middle;">افزودن به سبد خرید</a>
                                 </form>
                             </div>
                             <div class="product-link">
                                 <ul class="list-inline">
                                     <li><a href="/Home/Wishlist">افزودن به علاقه‌مندی‌ها</a></li>
                                     <li><a href="#">اشتراک‌گذاری</a></li>
                                 </ul>
                             </div>
                            <p class="ptb-20">@Model.ShortDescription</p>
                            
                            @if (Model.Tags != null && Model.Tags.Any())
                            {
                                <div class="mt-20">
                                    <strong>برچسب‌ها: </strong>
                                    @foreach (var tag in Model.Tags)
                                    {
                                        <a href="/Home/Shop?tagId=@tag.TagId" class="badge badge-secondary" style="background-color: #f8f9fa; color: #495057; padding: 5px 10px; border-radius: 4px; border: 1px solid #dee2e6; margin-left: 5px; text-decoration: none; display: inline-block;"># @tag.Title</a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <!-- Thumbnail Description End -->
                </div>
                <!-- Row End -->
            </div>
            <!-- Container End -->
        </div>
        <!-- Product Thumbnail End -->
        <!-- Product Thumbnail Description Start -->
        <div class="thumnail-desc pb-60">
            <div class="container">
                <div class="row">
                    <div class="col-sm-12">
                        <ul class="main-thumb-desc nav">
                            <li><a class="active" data-toggle="tab" href="#dtail">توضیحات</a></li>
                            <li><a data-toggle="tab" href="#review">نظرات (1)</a></li>
                        </ul>
                        <!-- Product Thumbnail Tab Content Start -->
                        <div class="tab-content thumb-content border-default">
                            <div id="dtail" class="tab-pane in active">
                                <p>@Html.Raw(Model.Description ?? Model.ShortDescription)</p>
                            </div>
                            <div id="review" class="tab-pane">
                                <!-- Reviews Start -->
                                <div class="review">
                                    <div class="group-title">
                                        <h2>نظرات مشتریان</h2>
                                    </div>
                                    <h4 class="review-mini-title">جانتریک</h4>
                                    <ul class="review-list">
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>کیفیت</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                            <label>جانتریک</label>
                                        </li>
                                        <!-- Single Review List End -->
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>قیمت</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                            <label>دیدگاه توسط <a href="https://themeforest.net/user/Jantrik">جانتریک</a></label>
                                        </li>
                                        <!-- Single Review List End -->
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>ارزش خرید</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                            <label>ارسال شده در 7/20/18</label>
                                        </li>
                                        <!-- Single Review List End -->
                                    </ul>
                                </div>
                                <!-- Reviews End -->
                                <!-- Reviews Start -->
                                <div class="review border-default universal-padding mt-30">
                                    <h2 class="review-title mb-30">دیدگاه خود را بنویسید برای: <br><span> Go-Get'r Pushup Grips</span></h2>
                                    <p class="review-mini-title">امتیاز شما</p>
                                    <ul class="review-list">
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>کیفیت</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                        </li>
                                        <!-- Single Review List End -->
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>قیمت</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                            <i class="fa fa-star-o"></i>
                                        </li>
                                        <!-- Single Review List End -->
                                        <!-- Single Review List Start -->
                                        <li>
                                            <span>ارزش خرید</span>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star-o"></i>
                                        </li>
                                        <!-- Single Review List End -->
                                    </ul>
                                    <!-- Reviews Field Start -->
                                    <div class="riview-field mt-40">
                                        <form autocomplete="off" action="#">
                                            <div class="form-group">
                                                <label class="req" for="sure-name">نام مستعار</label>
                                                <input type="text" class="form-control" id="sure-name" required="required">
                                            </div>
                                            <div class="form-group">
                                                <label class="req" for="subject">خلاصه نظر</label>
                                                <input type="text" class="form-control" id="subject" required="required">
                                            </div>
                                            <div class="form-group">
                                                <label class="req" for="comments">متن نظر</label>
                                                <textarea class="form-control" rows="5" id="comments" required="required"></textarea>
                                            </div>
                                            <button type="submit" class="btn-submit">ثبت نظر</button>
                                        </form>
                                    </div>
                                    <!-- Reviews Field Start -->
                                </div>
                                <!-- Reviews End -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Product Thumbnail Description End -->
        <!-- Realted Product Start -->
        <div class="related-product pb-30">
            <div class="container">
                <div class="related-box">
                    <div class="group-title">
                        <h2>محصولات مرتبط</h2>
                    </div>
                    <!-- Realted Product Activation Start -->                    
                    <div class="new-upsell-pro owl-carousel">
                        @if (ViewBag.RelatedProducts != null)
                        {
                            foreach (var related in (List<Azimzadeh_MVC_project.Models.Product>)ViewBag.RelatedProducts)
                            {
                                var mainImage = related.ProductImages.FirstOrDefault(img => img.IsMain) ?? related.ProductImages.FirstOrDefault();
                                var mainImagePath = mainImage != null ? mainImage.ImagePath : "/assets/img/products/1.jpg";
                                var hoverImage = related.ProductImages.FirstOrDefault(img => !img.IsMain) ?? mainImage;
                                var hoverImagePath = hoverImage != null ? hoverImage.ImagePath : mainImagePath;

                                <!-- Single Product Start -->                    
                                <div class="single-product">
                                    <!-- Product Image Start -->
                                    <div class="pro-img">
                                        <a href="/Home/Product?id=@related.ProductId">
                                            <img class="primary-img" src="@mainImagePath" alt="@related.Title">
                                            <img class="secondary-img" src="@hoverImagePath" alt="@related.Title">
                                        </a>
                                    </div>
                                    <!-- Product Image End -->
                                    <!-- Product Content Start -->
                                    <div class="pro-content">
                                        <div class="product-rating">
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                        </div>                                
                                        <h4><a href="/Home/Product?id=@related.ProductId">@related.Title</a></h4>
                                        <p>
                                            @if (related.DiscountPrice.HasValue)
                                            {
                                                <span class="price">@related.DiscountPrice.Value.ToString("N0") ریال</span>
                                                <del class="prev-price">@related.Price.ToString("N0") ریال</del>
                                            }
                                            else
                                            {
                                                <span class="price">@related.Price.ToString("N0") ریال</span>
                                            }
                                        </p>
                                        <div class="pro-actions">
                                            <div class="actions-secondary">
                                                <a href="/Home/Wishlist" data-toggle="tooltip" title="افزودن به علاقه‌مندی‌ها"><i class="fa fa-heart"></i></a>
                                                <a class="add-cart" href="/Home/Cart" data-toggle="tooltip" title="افزودن به سبد خرید">افزودن به سبد خرید</a>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Product Content End -->
                                    @if (related.DiscountPrice.HasValue)
                                    {
                                        var discountPercent = (int)Math.Round((double)(related.Price - related.DiscountPrice.Value) / (double)related.Price * 100);
                                        <span class="sticker-new">-@discountPercent%</span>
                                    }
                                </div>
                                <!-- Single Product End -->
                            }
                        }
                    </div>
                    <!-- Realted Product Activation End -->
                </div>
            </div>
        </div>
        <!-- Realted Product End -->
        <!-- Upsell Product Start -->
        <div class="related-product pb-30">
            <div class="container">
                <div class="usel-product">
                    <div class="group-title">
                        <h2>upsell product</h2>
                    </div>
                    <!-- Upsell Product Activation Start -->
                    <div class="new-upsell-pro owl-carousel">
                        @if (ViewBag.UpsellProducts != null)
                        {
                            foreach (var upsell in (List<Azimzadeh_MVC_project.Models.Product>)ViewBag.UpsellProducts)
                            {
                                var mainImage = upsell.ProductImages.FirstOrDefault(img => img.IsMain) ?? upsell.ProductImages.FirstOrDefault();
                                var mainImagePath = mainImage != null ? mainImage.ImagePath : "/assets/img/products/1.jpg";
                                var hoverImage = upsell.ProductImages.FirstOrDefault(img => !img.IsMain) ?? mainImage;
                                var hoverImagePath = hoverImage != null ? hoverImage.ImagePath : mainImagePath;

                                <!-- Single Product Start -->                    
                                <div class="single-product">
                                    <!-- Product Image Start -->
                                    <div class="pro-img">
                                        <a href="/Home/Product?id=@upsell.ProductId">
                                            <img class="primary-img" src="@mainImagePath" alt="@upsell.Title">
                                            <img class="secondary-img" src="@hoverImagePath" alt="@upsell.Title">
                                        </a>
                                    </div>
                                    <!-- Product Image End -->
                                    <!-- Product Content Start -->
                                    <div class="pro-content">
                                        <div class="product-rating">
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                            <i class="fa fa-star"></i>
                                        </div>                                
                                        <h4><a href="/Home/Product?id=@upsell.ProductId">@upsell.Title</a></h4>
                                        <p>
                                            @if (upsell.DiscountPrice.HasValue)
                                            {
                                                <span class="price">@upsell.DiscountPrice.Value.ToString("N0") ریال</span>
                                                <del class="prev-price">@upsell.Price.ToString("N0") ریال</del>
                                            }
                                            else
                                            {
                                                <span class="price">@upsell.Price.ToString("N0") ریال</span>
                                            }
                                        </p>
                                        <div class="pro-actions">
                                            <div class="actions-secondary">
                                                <a href="/Home/Wishlist" data-toggle="tooltip" title="افزودن به علاقه‌مندی‌ها"><i class="fa fa-heart"></i></a>
                                                <a class="add-cart" href="/Home/Cart" data-toggle="tooltip" title="افزودن به سبد خرید">افزودن به سبد خرید</a>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Product Content End -->
                                    @if (upsell.DiscountPrice.HasValue)
                                    {
                                        var discountPercent = (int)Math.Round((double)(upsell.Price - upsell.DiscountPrice.Value) / (double)upsell.Price * 100);
                                        <span class="sticker-new">-@discountPercent%</span>
                                    }
                                </div>
                                <!-- Single Product End -->
                            }
                        }
                    </div>
                    <!-- Upsell Product Activation End -->
                </div>
            </div>
        </div>
        <!-- Upsell Product End -->
        <!-- Brand Logo Start -->
        <div class="brand-area pb-60">
            <div class="container">
                <!-- Brand Banner Start -->
                <div class="brand-banner owl-carousel">
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img class="img" src="/assets/img/brand/1.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/2.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/3.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/4.png" alt="brand-image"></a>
                    </div>
                    <div class="single-brand">
                        <a href="#"><img src="/assets/img/brand/5.png" alt="brand-image"></a>
                    </div>
                </div>
                <!-- Brand Banner End -->                
            </div>
        </div>
        <!-- Brand Logo End -->

        